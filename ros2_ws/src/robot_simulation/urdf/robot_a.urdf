<?xml version="1.0" encoding="utf-8"?>
<robot name="robot_a">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.54074" /> 
      <inertia ixx="0.007512" ixy="0" ixz="0" iyy="0.014051" iyz="0" izz="0.019808" />
    </inertial>
    <visual>
      <geometry><box size="0.31 0.22 0.08"/></geometry>
      <material name="white"><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <geometry><box size="0.31 0.22 0.08"/></geometry>
    </collision>
  </link>

  <link name="link_br">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.2355" /> 
      <inertia ixx="0.00008354" ixy="0" ixz="0" iyy="0.00014178" iyz="0" izz="0.00008354" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><cylinder radius="0.0347" length="0.0255"/></geometry>
      <material name="blue"><color rgba="0 0 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><sphere radius="0.0347"/></geometry>
    </collision>
  </link>

  <joint name="joint_br" type="continuous">
    <origin xyz="-0.08535 -0.125 -0.02105" rpy="0 0 0" />
    <parent link="base_link" /><child link="link_br" /><axis xyz="0 1 0" />
    <limit effort = "2.37" velocity = "17.25"/>
  </joint>

  <link name="link_bl">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.2355" />
      <inertia ixx="0.00008354" ixy="0" ixz="0" iyy="0.00014178" iyz="0" izz="0.00008354" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><cylinder radius="0.0347" length="0.0255"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><sphere radius="0.0347"/></geometry>
    </collision>
  </link>

  <joint name="joint_bl" type="continuous">
    <origin xyz="-0.08535 0.125 -0.02105" rpy="0 0 0" />
    <parent link="base_link" /><child link="link_bl" /><axis xyz="0 1 0" />
    <limit effort = "2.37" velocity = "17.25"/>
  </joint>

  <link name="caster_swivel">
    <inertial>
      <mass value="0.001" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="swivel_joint" type="fixed">
    <origin xyz="0.0965 0 -0.048" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_swivel" />
    <axis xyz="0 0 1" /> 
  </joint>

  <link name="link_front">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><sphere radius="0.007995"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><sphere radius="0.007995"/></geometry>
    </collision>
  </link>

  <joint name="joint_front" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="caster_swivel" />
    <child link="link_front" />
    <axis xyz="0 1 0" /> 
  </joint>


  <link name="imu_link">
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link" />
    <child link="imu_link" />
    <origin xyz="-0.08535 0 -0.045" rpy="3.14159 0 0" />
  </joint>

  <link name="lidar_link">
    <inertial>
      <mass value="0.052" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.000004" ixy="0" ixz="0" iyy="0.000004" iyz="0" izz="0.000004" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.02425" rpy="0 0 0" />
      <geometry><cylinder radius="0.0125" length="0.0485"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02425" rpy="0 0 0" />
      <geometry><cylinder radius="0.0125" length="0.0485"/></geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
  </joint>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="webots_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan><horizontal><samples>360</samples><resolution>1.0</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
        <range><min>0.12</min><max>3.5</max><resolution>0.015</resolution></range>
      </ray>
    </sensor>
  </gazebo>

  <link name="camera_link">
  <inertial>
    <mass value="0.004" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <inertia ixx="0.0000003" ixy="0" ixz="0" iyy="0.0000002" iyz="0" izz="0.0000002" />
  </inertial>
  <visual>
    <geometry>
      <box size="0.0045 0.025 0.023"/>
    </geometry>
    <material name="red"><color rgba="1 0 0 1" /></material>
  </visual>
</link>

  <joint name="camera_joint" type="fixed">
    <parent link ="base_link"></parent>
    <child link ="camera_link"></child>
    <origin xyz="0.1595 0 0.00364" rpy="-1.508 0 -1.508" />
  </joint>
  <gazebo reference="camera_link">
  <sensor type="camera" name="my_webots_camera">
    <alwaysOn>true</alwaysOn>
    <visualize>true</visualize>
    <update_rate>10</update_rate>
    <camera>
      <horizontal_fov>1.047</horizontal_fov>
      <image>
        <width>640</width>
    <height>480</height>
    <format>R8G8B8</format>
      </image>
      <clip>
       <near>0.02</near>
      <far>10.0</far>
     </clip>
    </camera>
    </sensor>
</gazebo>


  <link name="gps_link">
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link" />
    <child link="gps_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <ros2_control name="WebotsControl" type="system">
    <hardware>
      <plugin>webots_ros2_control::Ros2ControlSystem</plugin>
    </hardware>
    <joint name="joint_bl">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_br">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  
  <webots>
    <plugin type="webots_ros2_control::Ros2Control" />
    
    <device reference="webots_lidar" type="Lidar">
      <ros><enabled>true</enabled><updateRate>10</updateRate><topicName>/scan</topicName><alwaysOn>true</alwaysOn></ros>
    </device>

    <device reference= "my_webots_camera" type = "Camera">
      <ros>
        <topicName>/camera/image_raw</topicName>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>
  
    <plugin type="webots_ros2_driver::Ros2IMU">
      <enabled>true</enabled>
      <topicName>/imu/data</topicName>
      <alwaysOn>true</alwaysOn>
      <frameName>imu_link</frameName>
      <inertialUnitName>my_imu</inertialUnitName>
      <gyroName>gyro</gyroName>
      <accelerometerName>accelerometer</accelerometerName>
    </plugin>

    <device reference="gps" type="GPS">
      <ros>
        <enabled>true</enabled>
        <alwaysOn>true</alwaysOn>
        <topicName>/gps</topicName>
        <frameName>gps_link</frameName>
      </ros>
    </device>
  
    
  </webots>
</robot>