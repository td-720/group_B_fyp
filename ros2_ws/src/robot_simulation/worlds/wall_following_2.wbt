DEF MY_ROBOT Robot {
  translation -4.16 -4.22 0.056
  rotation 0 0 -1 -1.5707996938995747
  children [

    GPS {
      name "gps"
    }
    InertialUnit {
      translation -0.08535 0 -0.04
      rotation 1 0 0 3.14159
      name "my_imu"
    }
    Gyro {
      translation -0.085 0 -0.04
      rotation 1 0 0 3.14159
      name "gyro"
      lookupTable [
        -1000 -1000 0.010
        1000 1000 0.010
      ]
    }
    Accelerometer {
      translation -0.085 0 -0.04
      rotation 1 0 0 3.14159
      name "accelerometer"
      lookupTable [
        -1000 -1000 0.010
        1000 1000 0.010
      ]
    }
    Shape {
      appearance DEF white PBRAppearance { roughness 1 metalness 0 }
      geometry Box { size 0.31 0.22 0.08 }
    }
    # --- RIGHT MOTOR ---
    HingeJoint {
      jointParameters HingeJointParameters {
        position 0
        axis 0 1 0
        anchor -0.08535 -0.125 -0.02105
      }
      device [
        RotationalMotor {
          name "joint_br"
          maxVelocity 17.29
          maxTorque 1.2
        }
        PositionSensor { 
          name "joint_br_sensor" 
          resolution 0.05236
          noise 0.020
        }
      ]
      endPoint Solid {
        translation -0.08535 -0.125 -0.02105
        children [
          Pose {
            rotation 1 0 0 1.5708
            children [
              Shape {
                appearance DEF blue PBRAppearance { baseColor 0 0 1 roughness 1 metalness 0 }
                geometry Cylinder { height 0.0255 radius 0.0347 }
              }
            ]
          }
        ]
        name "link_br"
        boundingObject Pose {
          rotation 1 0 0 1.5708
          children [ Sphere { radius 0.0347 } ]
        }
        physics Physics {
          density -1
          mass 0.02355
          centerOfMass [ 0 0 0 ]
          inertiaMatrix [ 8.354e-05 0.00014178 8.354e-05, 0 0 0 ]
        }
      }
    }
    # --- LEFT MOTOR ---
    HingeJoint {
      jointParameters HingeJointParameters {
        position 0
        axis 0 1 0
        anchor -0.08535 0.125 -0.02105
      }
      device [
        RotationalMotor {
          name "joint_bl"
          maxVelocity 17.29
          maxTorque 1.2
        }
        PositionSensor { 
          name "joint_bl_sensor" 
          resolution 0.05236
          noise 0.020
        }
      ]
      endPoint Solid {
        translation -0.08535 0.125 -0.02105
        children [
          Pose {
            rotation 1 0 0 1.5708
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.5 0.5 0.5 roughness 1 metalness 0 }
                geometry Cylinder { height 0.0255 radius 0.0347 }
              }
            ]
          }
        ]
        name "link_bl"
        boundingObject Pose {
          rotation 1 0 0 1.5708
          children [ Sphere { radius 0.0347 } ]
        }
        physics Physics {
          density -1
          mass 0.02355
          centerOfMass [ 0 0 0 ]
          inertiaMatrix [ 8.354e-05 0.00014178 8.354e-05, 0 0 0 ]
        }
      }
    }
    # --- FRONT CASTER ---
    Solid {
      translation 0.0965 0 -0.048
      children [
        Solid {
          children [
            Shape {
              appearance DEF grey PBRAppearance { baseColor 0.5 0.5 0.5 roughness 1 metalness 0 }
              geometry Sphere { radius 0.007995 }
            }
          ]
          name "link_front"
          contactMaterial "frictionless_caster"
          boundingObject Sphere { radius 0.007995 }
          physics Physics {
            density -1
            mass 0.05
            centerOfMass [ 0 0 0 ]
            inertiaMatrix [ 1e-06 1e-06 1e-06, 0 0 0 ]
          }
        }
      ]
