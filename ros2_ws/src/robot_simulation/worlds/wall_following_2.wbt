        density -1
        mass 0.001
        centerOfMass [ 0 0 0 ]
        inertiaMatrix [ 1e-06 1e-06 1e-06, 0 0 0 ]
      }
    }
    # --- LIDAR ---
    Solid {
      translation 0 0 0.04
      children [
        Pose {
          translation 0 0 0.02425
          children [
            Shape {
              appearance DEF dark_grey PBRAppearance { baseColor 0.2 0.2 0.2 roughness 1 metalness 0 }
              geometry Cylinder { height 0.0485 radius 0.0125 }
            }
          ]
        }
        Lidar {
          name "webots_lidar"
