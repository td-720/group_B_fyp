WorldInfo {
  basicTimeStep 20
  contactProperties [
    ContactProperties {
      material1 "frictionless_caster"
      coulombFriction [ 0 ] # <--- FIXED: Now truly frictionless for turning
      bounce 0
    }
    ContactProperties {
      material1 "default"
      coulombFriction [ 0.85 ] # <--- FIXED: Set World/Floor friction explicitly to 0.85
      bounce 0
    }
  ]
}

